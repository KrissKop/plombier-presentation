# Port HTTP du serveur (fourni automatiquement par la plupart des hebergeurs)
PORT=3000

# Domaine(s) autorise(s) a appeler l'API en cross-origin (laisser vide en prod si front + back sont sur le meme domaine)
CORS_ORIGIN=

# SMTP pour l'envoi d'email a chaque nouvelle demande de devis.
# Sans ces variables, le serveur fonctionne normalement et enregistre
# simplement les demandes dans data/leads.jsonl sans envoyer d'email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TO_EMAIL=contact@aquaflex-plomberie.fr

# Jeton secret pour consulter GET /api/leads (laisser vide pour desactiver la route)
ADMIN_TOKEN=
